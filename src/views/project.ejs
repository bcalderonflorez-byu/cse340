<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= projectDetails.title %></h2>
    <p>Description: <%= projectDetails.description %></p>
    <p><%= new Date(projectDetails.project_date).toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'}) %></p>
    <p>Location: <%= projectDetails.location %></p>
    <p>Organization: <a href="/organization/<%= projectDetails.organization_id %>"><%= projectDetails.name %></a></p>
    <p>Category:
        <% projectCategoriesDetails.forEach((category, index) => { %>
           <a href="/category/<%= category.category_id%>"> <%= category.category_name %><%= index < projectCategoriesDetails.length - 1 ? ' - ' : '' %></a>
        <% }); %>
    </p>
</main>
<%- include('partials/footer') %>