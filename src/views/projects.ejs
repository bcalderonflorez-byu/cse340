<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        
        <h2>Upcoming Service Projects</h2>
        <ul>

            <% projects.forEach(projects => { %>                
                <li><strong><%= new Date(projects.project_date)
                            .toLocaleDateString(
                                'en-US',
                                {
                                    year:'numeric',
                                    month:'long',
                                    day:'numeric'
                                }
                            ) %>
                    </strong>: 
                    <a href="/project/<%= projects.project_id %>"><%= projects.title %></a>    
                    ( <a href="/organization/<%= projects.organization_id %>"><%= projects.name %></a> )
                </li>
      
            
            <% }); %>
        </ul>
    </main>

<%- include('partials/footer') %>